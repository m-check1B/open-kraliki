# =============================================================================
# Kraliki OS — Environment Variables
# =============================================================================
# Copy this to .env and fill in your values:
#   cp env.example .env
#
# Then source it in your shell profile (~/.zshrc or ~/.bashrc):
#   source $HOME/github/open-kraliki/.env
# =============================================================================

# --- Linear API ---
# Get your API key from: https://linear.app/settings/api
export LINEAR_API_KEY="lin_api_YOUR_KEY_HERE"

# Your Linear team UUID (Settings → Team → copy from URL)
export LINEAR_TEAM_ID="00000000-0000-0000-0000-000000000000"

# Short team key prefix (e.g., PROJ, APP, SVC)
export LINEAR_TEAM_KEY="PROJ"

# --- Telegram Bot ---
# Create a bot via @BotFather, get the token
export TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."

# Your personal chat ID (message @userinfobot to find it)
export PA_OWNER_CHAT_ID="123456789"

# --- Groq API (optional, for voice transcription) ---
# Get from: https://console.groq.com/keys
export GROQ_API_KEY="gsk_YOUR_KEY_HERE"

# --- Project ---
# Absolute path to your project repository
# IMPORTANT: Use a DEDICATED clone for automation, not your working copy!
# Fixers run `git reset --hard` which DESTROYS uncommitted changes.
# Example: git clone git@github.com:you/your-project.git ~/github/your-project-automation
export PROJECT_DIR="$HOME/github/your-project"

# Branch to work on (fixers will fetch+reset to this)
export PROJECT_BRANCH="main"

# --- Issue Prefixes ---
# Prefix for auto-created QA issues (e.g., "[AI-QA] Bug: ...")
export ISSUE_PREFIX="[AI-QA]"

# Prefix for auto-fix commits (e.g., "[AI-FIX] Fix: ...")
export COMMIT_PREFIX="[AI-FIX]"

# --- Active Hours (24h format) ---
# Fixers only run during these hours (default: 24/7)
export ACTIVE_START=0
export ACTIVE_END=24

# Relay active hours (when the Telegram bot responds)
export RELAY_ACTIVE_START=8
export RELAY_ACTIVE_END=23

# Heartbeat active hours (when periodic briefings are sent)
export HEARTBEAT_ACTIVE_START=8
export HEARTBEAT_ACTIVE_END=23

# --- Timeouts (seconds) ---
# Max time a fixer CLI gets to fix a single issue
export FIX_TIMEOUT=600

# Max time the relay CLI gets to respond to a message
export RELAY_CLI_TIMEOUT=120

# Max time the watchdog recovery CLI gets
export WATCHDOG_RECOVERY_TIMEOUT=300

# --- Intervals ---
# Telegram relay poll interval (seconds between checks for new messages)
export RELAY_POLL_INTERVAL=3

# How many hours without commits before watchdog warns
export COMMIT_FRESHNESS_HOURS=2

# Days to keep log files before auto-deletion
export LOG_RETENTION_DAYS=7

# --- Relay Settings ---
# CLI command the Telegram relay uses to generate responses
export RELAY_CLI_CMD="claude --print"

# Language for voice transcription (ISO 639-1 code, e.g. "en", "cs", "de")
export WHISPER_LANGUAGE="en"

# Directory for relay conversation logs
export RELAY_LOG_DIR="$HOME/logs/relay/conversations"

# CLI command the heartbeat uses for analysis
export HEARTBEAT_CLI="claude"

# CLI command the watchdog uses for recovery
export RECOVERY_CLI="opencode"

# --- Precheck Settings ---
# Max issues to return per fixer per cycle (default: 10)
export MAX_ISSUES=10

# Comma-separated label names to skip (issues with these labels are ignored)
export SKIP_LABELS="wont-fix,manual,flaky"

# --- LaunchAgent Labels (override if you renamed them) ---
# export ORCHESTRATOR_AGENT="com.automation.fixer-orchestrator"
# export RELAY_AGENT="com.automation.telegram-relay"

# --- Remote Server (optional, for watchdog check 6) ---
# SSH user@host for remote process monitoring
# export PRODUCTION_SERVER="user@your-server.com"

# --- CLI Tools ---
# These should be on your PATH. The template ships with 4 fixer slots:
#   Slot 0: claude (Claude Code CLI)
#   Slot 1: codex  (Codex CLI)
#   Slot 2: opencode (Opencode CLI)
#   Slot 3: kimi   (Kimi Code CLI)
# You can use any AI coding CLI — just update the fixer scripts.
# To run fewer fixers, edit the FIXERS array in automation/fixer-orchestrator.sh.
